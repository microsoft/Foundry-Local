{
  "name": "foundry-local",
  "version-semver": "0.1.0",
  "description": "Foundry Local C++ SDK",
  "builtin-baseline": "44819aa2a6c10e56065e2b0330e7d6c89d1d2574",
  "dependencies": [
    "azure-storage-blobs-cpp",
    "ms-gsl",
    "nlohmann-json",
    "spdlog"
  ],
  "overrides": [
    { "name": "nlohmann-json", "version": "3.11.3" },
    { "name": "oatpp", "version": "1.3.0" }
  ],
  "features": {
    "service": {
      "description": "Build web service support (not available on Android)",
      "dependencies": [
        "oatpp"
      ]
    },
    "telemetry": {
      "description": "Build with 1DS (cpp-client-telemetry) telemetry uploads",
      "dependencies": [
        "cpp-client-telemetry"
      ]
    },
    "tests": {
      "description": "Build unit tests",
      "dependencies": [
        "gtest",
        {
          "name": "cpp-httplib",
          "features": ["openssl"]
        }
      ]
    }
  }
}
