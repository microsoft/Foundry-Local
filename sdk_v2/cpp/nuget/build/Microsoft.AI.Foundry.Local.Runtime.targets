<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Non-transitive version: applies only to the project that directly references
       the Microsoft.AI.Foundry.Local.Runtime NuGet package. Copies the native
       foundry_local binary for the active RID to the output directory. -->

  <PropertyGroup Condition="'$(RuntimeIdentifier)' == ''">
    <RuntimeIdentifier>$(NETCoreSdkRuntimeIdentifier)</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(FoundryLocalRuntimePath)\$(RuntimeIdentifier)\native')">
    <Content Include="$(FoundryLocalRuntimePath)\$(RuntimeIdentifier)\native\*.*">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

</Project>
