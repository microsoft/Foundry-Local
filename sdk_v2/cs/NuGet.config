<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <add key="DefaultTlsVersions" value="1.2,1.3" />
  </config>
  <packageSources>
    <clear />
    <!--
    Only one feed allowed — OneBranch Secure Supply Chain policy rejects multiple feeds.
    See: https://eng.ms/docs/coreai/devdiv/one-engineering-system-1es/1es-docs/secure-supply-chain/secure-supply-chain-analysis-task/cfs-detectors/nuget/cfs-nuget#multiple-feeds-declared

    For local development with a local Runtime NuGet, create a NuGet.config.user:
      <packageSources>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <add key="foundry-local" value="../nuget/local" />
      </packageSources>
    -->
    <add key="ORT-Nightly" value="https://pkgs.dev.azure.com/aiinfra/PublicPackages/_packaging/ORT-Nightly/nuget/v3/index.json" />
  </packageSources>
</configuration>
