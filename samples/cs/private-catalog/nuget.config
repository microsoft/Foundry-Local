<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    This sample builds the SDK from source (see the ProjectReference in
    PrivateCatalog.csproj) rather than consuming the published
    Microsoft.AI.Foundry.Local NuGet package, because it exercises private-catalog
    APIs that aren't published yet. The SDK source pulls
    Microsoft.AI.Foundry.Local.Core 1.2.1 and ONNX Runtime — all released on
    nuget.org. Unlike the other samples it does NOT need the ORT-Nightly dev feed.

    Restricting this sample to nuget.org (overriding the parent samples/cs/nuget.config)
    keeps NuGet from ever querying ORT-Nightly for the released Core package, whose
    nuget.org upstream returns 401 on unauthenticated CI agents.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
