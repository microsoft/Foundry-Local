<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="AIFoundryLocal_PublicPackages" value="https://pkgs.dev.azure.com/aiinfra/AIFoundryLocal/_packaging/AIFoundryLocal_PublicPackages/nuget/v3/index.json" />
  </packageSources>

  <!--
    The AIFoundryLocal_PublicPackages feed requires authentication and is only
    needed for WinML builds to resolve private Core packages.  It is disabled
    by default so that normal restores do not trigger credential prompts.

    The CI pipeline generates its own NuGet.config with this feed enabled and
    authenticates via the NuGetAuthenticate task (see build-cs-steps.yml).

    Note: packageSourceMapping was considered but NuGet authenticates against
    all enabled sources regardless of whether any packages match the mapping.
  -->
  <disabledPackageSources>
    <clear />
    <add key="AIFoundryLocal_PublicPackages" value="true" />
  </disabledPackageSources>
</configuration>
